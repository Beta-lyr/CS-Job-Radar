# Database (Neon PostgreSQL)
# 1. 注册 https://neon.tech
# 2. 创建 project，获取连接串
# 3. 连接池模式用 ?sslmode=require&pooled=true&pgbouncer=true
DATABASE_URL=postgresql://user:password@ep-example-xxxx.us-east-2.aws.neon.tech/cs-job-radar?sslmode=require

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM (optional, skip AI analysis if empty)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
